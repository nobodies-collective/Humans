@model Humans.Web.Models.ShiftCardsViewModel

@if (Model.NextShifts.Count > 0 || Model.UrgentShifts.Count > 0)
{
    <div class="row g-4 mb-4">
        @if (Model.NextShifts.Count > 0)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between">
                        <h5 class="mb-0">My Shifts</h5>
                        @if (Model.PendingCount > 0)
                        {
                            <span class="badge bg-warning">@Model.PendingCount pending</span>
                        }
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            @foreach (var item in Model.NextShifts)
                            {
                                <li class="mb-2">
                                    <strong>@item.Signup.Shift.Title</strong>
                                    <br /><small class="text-muted">@item.DepartmentName &middot; @item.AbsoluteStart</small>
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="card-footer">
                        <a asp-controller="Shifts" asp-action="Mine" class="btn btn-sm btn-outline-primary">View All</a>
                    </div>
                </div>
            </div>
        }

        @if (Model.UrgentShifts.Count > 0)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0">Shifts Need Help</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            @foreach (var item in Model.UrgentShifts)
                            {
                                <li class="mb-2">
                                    <strong>@item.Shift.Title</strong>
                                    <span class="badge bg-danger">@item.RemainingSlots slots</span>
                                    <br /><small class="text-muted">@item.DepartmentName &middot; @item.AbsoluteStart</small>
                                </li>
                            }
                        </ul>
                    </div>
                    <div class="card-footer">
                        <a asp-controller="Shifts" asp-action="Index" class="btn btn-sm btn-outline-success">Browse Shifts</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
