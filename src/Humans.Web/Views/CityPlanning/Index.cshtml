@{
    ViewData["Title"] = "City Planning";
    var year = (int)ViewBag.Year;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.css" />
    <style>
        :root {
            --container-fill: var(--h-sepia);
        }
        .main-content { display: flex; max-width: 100vw; padding: 0; }
        main { display: flex; flex: 1; padding: 0; }
        #map-page { flex: 1; position: relative; overflow: hidden; }
        #map { height: 100%; width: 100%; }
    </style>
}

<div id="map-page">
    <div id="map" data-year="@year"></div>

    <div class="position-absolute top-0 end-0 m-3" style="z-index:10;">
        <div class="card shadow-sm">
            <div class="card-body py-2 px-3 d-flex flex-column gap-1">
                <button id="toggle-containers" class="btn btn-outline-secondary btn-sm active" aria-pressed="true">
                    <i class="fa-solid fa-box me-1"></i> @Localizer["ContainerMap_Legend_Title"]
                </button>
                <button id="toggle-camp-limits" class="btn btn-outline-secondary btn-sm active" aria-pressed="true">
                    <i class="fa-solid fa-draw-polygon me-1"></i> @Localizer["CityPlanning_CampLimits"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.js"></script>
    <script src="https://unpkg.com/@@turf/turf@7.1.0/turf.min.js"></script>
    <script type="module" src="~/js/city-planning/main.js"></script>
}
