@model Humans.Web.Models.ShiftAdminViewModel
@using Humans.Domain.Enums

@{
    ViewData["Title"] = $"Shifts - {Model.Department.Name}";
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Index">Teams</a></li>
            <li class="breadcrumb-item"><a asp-controller="Team" asp-action="Details" asp-route-slug="@Model.Department.Slug">@Model.Department.Name</a></li>
            <li class="breadcrumb-item active">Shifts</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@Model.Department.Name — Shifts</h2>
        <div>
            <span class="badge bg-primary fs-6">@Model.ConfirmedCount / @Model.TotalSlots filled</span>
        </div>
    </div>

    <vc:temp-data-alerts />

    @* Pending Approvals *@
    @if (Model.PendingSignups.Count > 0 && Model.CanApproveSignups)
    {
        <div class="card mb-4 border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Pending Approvals (@Model.PendingSignups.Count)</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr><th>Human</th><th>Shift</th><th>Submitted</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var signup in Model.PendingSignups)
                            {
                                <tr>
                                    <td>@signup.User?.DisplayName</td>
                                    <td>@signup.Shift.Title</td>
                                    <td>@signup.CreatedAt</td>
                                    <td>
                                        <form asp-action="ApproveSignup" asp-route-slug="@Model.Department.Slug" asp-route-signupId="@signup.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                        </form>
                                        <form asp-action="RefuseSignup" asp-route-slug="@Model.Department.Slug" asp-route-signupId="@signup.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">Refuse</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @* Rotas *@
    @foreach (var rota in Model.Rotas)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0 d-inline">@rota.Name</h5>
                    <span class="badge bg-secondary ms-2">@rota.Priority</span>
                    <span class="badge bg-info ms-1">@rota.Policy</span>
                    @if (!rota.IsActive)
                    {
                        <span class="badge bg-danger ms-1">Inactive</span>
                    }
                </div>
            </div>
            <div class="card-body">
                @if (rota.Shifts.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Day</th>
                                    <th>Start</th>
                                    <th>Duration</th>
                                    <th>Slots</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var shift in rota.Shifts.OrderBy(s => s.DayOffset).ThenBy(s => s.StartTime))
                                {
                                    <tr class="@(!shift.IsActive ? "table-secondary" : "")">
                                        <td>
                                            @shift.Title
                                            @if (shift.AdminOnly) { <span class="badge bg-dark">Admin Only</span> }
                                        </td>
                                        <td>Day @shift.DayOffset</td>
                                        <td>@shift.StartTime</td>
                                        <td>@shift.Duration.TotalHours h</td>
                                        <td>@shift.ShiftSignups.Count(d => d.Status == SignupStatus.Confirmed) / @shift.MaxVolunteers</td>
                                        <td>
                                            @if (Model.CanManageShifts && shift.IsActive)
                                            {
                                                <form asp-action="DeactivateShift" asp-route-slug="@Model.Department.Slug" asp-route-shiftId="@shift.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Deactivate</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No shifts yet.</p>
                }

                @* Create Shift *@
                @if (Model.CanManageShifts && rota.IsActive)
                {
                    <div class="mt-3 border-top pt-3">
                        <h6>Add Shift</h6>
                        <form asp-action="CreateShift" asp-route-slug="@Model.Department.Slug" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="RotaId" value="@rota.Id" />
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <input type="text" name="Title" class="form-control form-control-sm" placeholder="Title" required />
                                </div>
                                <div class="col-md-2">
                                    <input type="number" name="DayOffset" class="form-control form-control-sm" placeholder="Day offset" value="0" />
                                </div>
                                <div class="col-md-2">
                                    <input type="time" name="StartTime" class="form-control form-control-sm" value="08:00" />
                                </div>
                                <div class="col-md-1">
                                    <input type="number" name="DurationHours" class="form-control form-control-sm" placeholder="Hours" value="4" step="0.5" />
                                </div>
                                <div class="col-md-1">
                                    <input type="number" name="MinVolunteers" class="form-control form-control-sm" placeholder="Min" value="1" />
                                </div>
                                <div class="col-md-1">
                                    <input type="number" name="MaxVolunteers" class="form-control form-control-sm" placeholder="Max" value="5" />
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-sm btn-primary">Add</button>
                                </div>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    }

    @* Create Rota *@
    @if (Model.CanManageShifts)
    {
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">Create Rota</h5></div>
            <div class="card-body">
                <form asp-action="CreateRota" asp-route-slug="@Model.Department.Slug" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Name</label>
                            <input type="text" name="Name" class="form-control" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Priority</label>
                            <select name="Priority" class="form-select">
                                <option value="Normal">Normal</option>
                                <option value="Important">Important</option>
                                <option value="Essential">Essential</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Policy</label>
                            <select name="Policy" class="form-select">
                                <option value="Public">Public</option>
                                <option value="RequireApproval">Require Approval</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Description</label>
                            <input type="text" name="Description" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary">Create</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
