@model IList<Humans.Domain.Entities.EmailOutboxMessage>
@{
    ViewData["Title"] = "My Emails";

    string TemplateFriendlyName(string templateName) => templateName switch
    {
        "welcome" => "Welcome",
        "campaign_code" => "Campaign Code",
        "email_verification" => "Email Verification",
        "deletion_confirmation" => "Deletion Confirmation",
        "consent_reminder" => "Consent Reminder",
        _ => templateName
    };
}

<div class="row">
    <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>My Emails</h1>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-left me-1"></i>Back to Profile
            </a>
        </div>

        <vc:temp-data-alerts />

        <p class="text-muted">Emails the system has sent to you (within the last 150 days).</p>

        @if (!Model.Any())
        {
            <div class="text-muted text-center py-5">No emails on record.</div>
        }
        else
        {
            <div class="card">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Template</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var msg in Model)
                            {
                                var statusClass = msg.Status switch
                                {
                                    EmailOutboxStatus.Queued => "bg-warning text-dark",
                                    EmailOutboxStatus.Sent => "bg-success",
                                    EmailOutboxStatus.Failed => "bg-danger",
                                    _ => "bg-secondary"
                                };
                                <tr>
                                    <td>@msg.Subject</td>
                                    <td>@TemplateFriendlyName(msg.TemplateName)</td>
                                    <td><span class="badge @statusClass">@msg.Status</span></td>
                                    <td>@msg.CreatedAt.ToDateTimeUtc().ToString("d MMM yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
